{
  "name": "subagent-mcp-server",
  "version": "0.1.0",
  "description": "MCP server that dispatches one-shot prompts to Codex (OpenAI) and Gemini (Google) coding agents as Claude Code subagents.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "subagent-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.128.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

      "mcp__agentboard__agentboard_health_check",
      "Bash(curl:*)",
      "Bash(npm test:*)",
      "Bash(npm run lint:*)",
      "Bash(git add:*)",
      "Read(//c/Users/maxco/.claude/plugins/cache/claude-code-plugins-plus/pi-pathfinder/1.0.0/skills/skill-adapter/references/**)",
      "Read(//c/Users/maxco/.claude/plugins/cache/claude-code-plugins-plus/pi-pathfinder/1.0.0/skills/skill-adapter/scripts/**)",
      "Read(//c/Users/maxco/.claude/plugins/cache/claude-code-plugins-plus/pi-pathfinder/1.0.0/skills/skill-adapter/assets/**)",
      "Read(//c/Users/maxco/.claude/plugins/cache/claude-code-plugins-plus/pi-pathfinder/1.0.0/**)",
      "Read(//c/Users/maxco/.claude/plugins/cache/claude-plugins-official/superpowers/4.3.1/skills/subagent-driven-development/**)",
      "Bash(git commit:*)",
      "Bash(python -m py_compile:*)",
      "Bash(npm run build:*)",
      "mcp__codebase-rag__rag_query_impact",
      "Read(//c/Users/maxco/Documents/agent-armory/mcp-servers/codegraph-mcp/dist/**)",
      "Read(//c/Users/maxco/**)",
      "mcp__agentboard__agentboard_get_app",
      "mcp__agentboard__agentboard_list_boards",
      "mcp__agentboard__agentboard_list_workspace_cards",
      "mcp__codegraph__codegraph_get_change_impact",
      "mcp__codegraph__codegraph_get_dependencies",
      "Bash(git diff:*)",
      "Edit(/.claude/skills/workspace-orchestration/**)"
    ],
    "additionalDirectories": [
      "C:\\Users\\maxco\\.agentboard"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "codebase-rag",
    "codegraph",
    "agentboard"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/rag-context.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-enforcer.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/reset-search-blocks.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-first-search.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__agentboard__agentboard_submit_workspace_artifact",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "SUBMISSION QUALITY GATE — Before submitting this artifact, verify ALL of the following:\n\n- No open questions or unanswered items\n- No TODO/TBD/FIXME/placeholder text\n- No 'need to investigate' or 'look into' language\n- Every step references specific files and line numbers\n- You used codegraph, codebase-rag, grep, and read tools to validate your work\n- The artifact is immediately actionable by another agent without further research\n\nIf ANY check fails, DO NOT submit. Go back and fix the gaps using your tools first."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/artifact-quality-gate.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/capture-task-output.py",
            "statusMessage": "Capturing task output"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Users/maxco/.claude/plugins/cache/claude-plugins-official/superpowers/4.3.1/hooks/run-hook.cmd\" session-start",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/contract-edit-guard.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-lint.sh",
            "timeout": 15000
          }
        ]
      },
      {
        "matcher": "mcp__agentboard__agentboard_get_next_card|mcp__agentboard__agentboard_get_card|mcp__agentboard__agentboard_update_workspace_card",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/workspace-card-guidance.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": []
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  }
}

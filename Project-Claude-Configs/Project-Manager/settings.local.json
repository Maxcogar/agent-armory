      "Bash(npm install:*)",
      "Bash(timeout 5 bash -c:*)",
      "Bash(node:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "mcp__codegraph__codegraph_get_dependents",
      "Bash(cd:*)",
      "mcp__codebase-rag__rag_search",
      "mcp__codegraph__codegraph_get_subgraph",
      "mcp__codegraph__codegraph_scan",
      "mcp__codegraph__codegraph_get_stats",
      "mcp__codegraph__codegraph_find_entry_points",
      "mcp__codegraph__codegraph_list_files",
      "mcp__agentboard__agentboard_list_projects",
      "mcp__agentboard__agentboard_get_activity_log",
